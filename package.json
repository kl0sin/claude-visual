{
  "name": "claude-visual",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun dev.ts",
    "dev:server": "bun --watch server/index.ts",
    "dev:client": "bunx vite",
    "build": "bunx vite build",
    "start": "NODE_ENV=production bun server/index.ts",
    "tauri:sidecar": "TRIPLE=$(rustc -vV | grep '^host:' | awk '{print $2}') && bun build --compile --outfile src-tauri/binaries/server-$TRIPLE server/index.ts",
    "tauri:dev": "bunx tauri dev",
    "tauri:build": "bun run tauri:sidecar && bunx tauri build"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.19",
    "@tauri-apps/api": "^2",
    "hono": "^4.12.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
